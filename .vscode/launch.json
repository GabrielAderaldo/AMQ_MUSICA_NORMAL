{
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Debug TS via ts-node",
        "runtimeArgs": [
          "--nolazy",
          "-r",
          "ts-node/register"
        ],
        "args": [
          "${workspaceFolder}/src/index.ts"
        ],
        "cwd": "${workspaceFolder}",
        "protocol": "inspector",
        "env": {
          "TS_NODE_FILES": "true"
        }
      }
    ]
  }